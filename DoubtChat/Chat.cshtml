@model EasyLearn.Models.DoubtChat
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = Model.Subject;
    var currentUser = await UserManager.GetUserAsync(User);
    var isInstructor = User.IsInRole("Instructor");
}

<link rel="stylesheet" href="~/css/doubt-chat.css" />

<div class="container mt-4 doubt-chat-container">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-0">@Model.Subject</h5>
                <small class="text-muted">
                    Course: @Model.Course.Title • 
                    Student: @Model.Student.FirstName @Model.Student.LastName
                    @if (Model.Instructor != null)
                    {
                        <text> • Instructor: @Model.Instructor.FirstName @Model.Instructor.LastName</text>
                    }
                </small>
            </div>
            <div>
                <span class="badge bg-info me-1">@Model.Category</span>
                <span class="badge bg-@(Model.Status == "Open" ? "warning" : "success")">@Model.Status</span>
                @if (isInstructor && Model.Status == "Open")
                {
                    <form method="post" action="/doubts/@Model.Id/resolve" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-success">Mark Resolved</button>
                    </form>
                }
            </div>
        </div>

        <div class="card-body" style="height: 500px; overflow-y: auto;" id="chatMessages">
            @foreach (var msg in Model.Messages.OrderBy(m => m.SentAt))
            {
                var isSender = msg.SenderId == currentUser!.Id;
                <div class="mb-3 @(isSender ? "text-end" : "")">
                    <div class="d-inline-block" style="max-width: 70%;">
                        <div class="card @(isSender ? "bg-primary text-white" : "bg-light")">
                            <div class="card-body p-2" style="@(isSender ? "" : "color: #000 !important;")">
                                <small class="d-block fw-bold" style="@(isSender ? "" : "color: #000 !important;")">@msg.Sender.FirstName @msg.Sender.LastName</small>
                                <p class="mb-1" style="@(isSender ? "" : "color: #000 !important;")">@msg.Message</p>
                                <small class="text-@(isSender ? "white-50" : "muted")" style="@(isSender ? "" : "color: #666 !important;")">@msg.SentAt.ToLocalTime().ToString("MMM dd, hh:mm tt")</small>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.Status == "Open")
        {
            <div class="card-footer">
                <form method="post" action="/doubts/@Model.Id/send" class="d-flex gap-2">
                    <input type="text" name="message" class="form-control" placeholder="Type your message..." required />
                    <button type="submit" class="btn btn-primary">Send</button>
                </form>
            </div>
        }
        else
        {
            <div class="card-footer text-center text-muted">
                This doubt has been resolved
            </div>
        }
    </div>

    <div class="mt-3">
        <a href="/doubts" class="btn btn-secondary">Back to Doubts</a>
    </div>
</div>

<script>
    // Auto-scroll to bottom
    document.addEventListener('DOMContentLoaded', function() {
        var chatMessages = document.getElementById('chatMessages');
        chatMessages.scrollTop = chatMessages.scrollHeight;
    });
</script>
